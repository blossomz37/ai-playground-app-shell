{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Electron App",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/app-shell"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/app-shell"
      },
      "problemMatcher": []
    },
    {
      "label": "Typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "options": {
        "cwd": "${workspaceFolder}/app-shell"
      },
      "problemMatcher": ["$tsc"]
    }
  ]
}
