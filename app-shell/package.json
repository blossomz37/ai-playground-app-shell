{
  "name": "app-shell",
  "productName": "App Shell",
  "version": "0.1.9",
  "description": "Reusable desktop shell — Electron + Svelte + SQLite",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "node scripts/start-dev.mjs",
    "build": "electron-vite build",
    "package:mac": "npm run build && node scripts/package-mac.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/renderer/tsconfig.json",
    "audit:contrast": "node scripts/audit-contrast.mjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3,keytar",
    "postinstall": "electron-rebuild -f -w better-sqlite3,keytar"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "better-sqlite3": "^12.11.1",
    "keytar": "^7.9.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "phosphor-svelte": "^3.1.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/notarize": "^3.1.1",
    "@electron/osx-sign": "^2.4.0",
    "@electron/packager": "^20.0.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "electron": "^42.5.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "playwright": "^1.61.1",
    "svelte": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  }
}
